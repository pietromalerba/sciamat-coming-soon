{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "sciamat_home_bg.jpg",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/shop/:path*",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/((?!sciamat_home_bg\\.jpg$).*)",
      "destination": "/",
      "permanent": false
    }
  ]
}